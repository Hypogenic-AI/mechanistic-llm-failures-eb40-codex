{"type":"item.started","item":{"id":"item_65","type":"command_execution","command":"/usr/bin/bash -lc \"pwd\ncat > datasets/.gitignore << 'EOF'\n# Exclude all data files (can be large)\n*\n\n# But include documentation and small samples\n\"'!.gitignore\n!README.md\n!**/README.md\n!**/samples/\n!**/samples/**\n!**/download.sh\n!**/download_instructions.txt\n!dataset_summary.json\nEOF\nsource .venv/bin/activate && python - << '\"'PY'\nimport os, json\nfrom datasets import load_dataset, load_from_disk\n\nspecs=[\n    ('commonsense_qa',None,'commonsense_multiple_choice'),\n    ('hellaswag',None,'commonsense_narrative_completion'),\n    ('winogrande','winogrande_debiased','pronoun_coreference_commonsense'),\n    ('allenai/ai2_arc','ARC-Challenge','science_commonsense_qa'),\n    ('truthful_qa','multiple_choice','truthfulness_and_reasoning'),\n]\nos.makedirs('datasets',exist_ok=True)\nsummary=[]\nfor name,cfg,task in specs:\n    out_name=(name.replace('/','_') + (f'_{cfg}' if cfg else ''))\n    out_dir=f'datasets/{out_name}'\n    if os.path.exists(out_dir):\n        ds=load_from_disk(out_dir)\n    else:\n        ds=load_dataset(name,cfg) if cfg else load_dataset(name)\n        ds.save_to_disk(out_dir)\n    sample_dir=f'{out_dir}/samples'\n    os.makedirs(sample_dir,exist_ok=True)\n    sample={}\n    counts={}\n    columns={}\n    for split in ds.keys():\n        counts[split]=len(ds[split])\n        columns[split]=ds[split].column_names\n        n=min(5,len(ds[split]))\n        sample[split]=[ds[split][i] for i in range(n)]\n    with open(f'{sample_dir}/examples.json','w') as f:\n        json.dump(sample,f,indent=2)\n    summary.append({\n        'name':out_name,\n        'source':f'huggingface:{name}' + (f'/{cfg}' if cfg else ''),\n        'task':task,\n        'splits':counts,\n        'columns':columns,\n        'location':out_dir,\n    })\n\nwith open('datasets/dataset_summary.json','w') as f:\n    json.dump(summary,f,indent=2)\nprint('datasets prepared',len(summary))\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
