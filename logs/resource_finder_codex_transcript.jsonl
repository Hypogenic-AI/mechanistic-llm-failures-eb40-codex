{"type":"item.started","item":{"id":"item_42","type":"command_execution","command":"/usr/bin/bash -lc \"pwd\nsource .venv/bin/activate && python - << 'PY'\nimport json, os, re, time, requests\nfrom urllib.parse import urlparse\n\nos.makedirs('papers', exist_ok=True)\nwith open('paper_finder_results_q2.json') as f:\n    data=json.load(f)\npapers=[p for p in data['papers'] if p.get('relevance',0)>=2]\n\nsess=requests.Session()\nheaders={'User-Agent':'Mozilla/5.0'}\n\n\ndef safe(s):\n    s=re.sub(r'[\"'^A-Za-z0-9._-]+'\"','_',s).strip('_')\n    return s[:120]\n\ndef s2id(url):\n    # .../paper/<id>\n    m=re.search(r'/paper/([0-9a-f]{40})',url)\n    return m.group(1) if m else None\n\ndef dl(url, out):\n    try:\n        with sess.get(url,headers=headers,timeout=30,stream=True,allow_redirects=True) as r:\n            if r.status_code\"'!=200:\n                return False,f'\"'status {r.status_code}'\n            ctype=r.headers.get('content-type','').lower()\n            if 'pdf' not in ctype and not r.url.lower().endswith('.pdf'):\n                # still may be pdf; inspect first bytes\n                first=next(r.iter_content(chunk_size=5),b'')\n                if first\"'!=b'\"'%PDF-':\n                    return False,f'not pdf ({ctype})'\n                with open(out,'wb') as f:\n                    f.write(first)\n                    for ch in r.iter_content(chunk_size=1024*128):\n                        if ch: f.write(ch)\n                return True,'ok'\n            with open(out,'wb') as f:\n                for ch in r.iter_content(chunk_size=1024*128):\n                    if ch: f.write(ch)\n        if os.path.getsize(out)<10_000:\n            return False,'too small'\n        return True,'ok'\n    except Exception as e:\n        return False,str(e)\n\nresults=[]\nfor i,p in enumerate(papers,1):\n    title=p.get('title','untitled')\n    year=p.get('year','na')\n    sid=s2id(p.get('url','') or '')\n    base=f\\\"{year}_{safe(title)}\\\"\n    out=f\\\"papers/{base}.pdf\\\"\n    if os.path.exists(out) and os.path.getsize(out)>10000:\n        results.append({'title':title,'year':year,'status':'exists','file':out,'source':''})\n        continue\n\n    pdf_url=None\n    arxiv_id=None\n    meta_err=''\n    if sid:\n        api=f\\\"https://api.semanticscholar.org/graph/v1/paper/{sid}?fields=title,year,externalIds,openAccessPdf,url\\\"\n        try:\n            mr=sess.get(api,headers=headers,timeout=30)\n            if mr.status_code==200:\n                m=mr.json()\n                oap=m.get('openAccessPdf') or {}\n                pdf_url=oap.get('url')\n                arxiv_id=(m.get('externalIds') or {}).get('ArXiv')\n            else:\n                meta_err=f'api status {mr.status_code}'\n        except Exception as e:\n            meta_err=str(e)\n\n    tried=[]\n    ok=False\n    reason=''\n    if pdf_url:\n        tried.append(pdf_url)\n        ok,reason=dl(pdf_url,out)\n    if (not ok) and arxiv_id:\n        aurl=f'https://arxiv.org/pdf/{arxiv_id}.pdf'\n        tried.append(aurl)\n        ok,reason=dl(aurl,out)\n    if (not ok) and sid:\n        # heuristic from semanticscholar page to arxiv id in title impossible; skip\n        pass\n\n    status='downloaded' if ok else 'failed'\n    if not ok and os.path.exists(out):\n        try: os.remove(out)\n        except: pass\n    results.append({'title':title,'year':year,'status':status,'file':out if ok else '', 'source':'; '.join(tried), 'reason': reason or meta_err})\n    if i%10==0:\n        print(f'{i}/{len(papers)} processed')\n    time.sleep(0.25)\n\nwith open('papers/download_log.json','w') as f:\n    json.dump(results,f,indent=2)\n\nok=sum(1 for r in results if r['status'] in ('downloaded','exists'))\nfail=len(results)-ok\nprint('target',len(results),'ok',ok,'fail',fail)\nPY\"","aggregated_output":"","exit_code":null,"status":"in_progress"}}
